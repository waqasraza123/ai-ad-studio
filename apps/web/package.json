{
  "name": "@ai-ad-studio/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:component": "vitest run --passWithNoTests --config vitest.component.config.ts",
    "test:e2e:full": "playwright test --config playwright.config.ts",
    "test:e2e:smoke": "playwright test --config playwright.config.ts --grep @smoke",
    "test:i18n-audit": "vitest run --passWithNoTests --config vitest.unit.config.ts src/lib/i18n/config.test.ts src/lib/i18n/resolve-locale.test.ts src/lib/i18n/translator.test.ts src/lib/i18n/catalog.test.ts src/lib/form-error-messages.test.ts src/lib/supabase/middleware.test.ts src/app/actions.test.ts",
    "test:unit": "vitest run --passWithNoTests --config vitest.unit.config.ts",
    "typecheck": "next typegen && tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
